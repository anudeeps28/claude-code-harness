      "updated": 1,
      "link": null,
      "locked": false,
      "text": "evaluator-agent  (Opus)   │ adversarial review\n  → spec compliance, security, regressions\n\nacceptance-test-agent     │ verifies criteria\n  → runs build, tests, end-to-end paths\n\n          parallel ║ independent reports\n                   ▼\n            STOP 3.6  —  you decide:\n               fix / skip / accept\n\n3 execute failures anywhere → /debug auto-fires",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "evaluator-agent  (Opus)   │ adversarial review\n  → spec compliance, security, regressions\n\nacceptance-test-agent     │ verifies criteria\n  → runs build, tests, end-to-end paths\n\n          parallel ║ independent reports\n                   ▼\n            STOP 3.6  —  you decide:\n               fix / skip / accept\n\n3 execute failures anywhere → /debug auto-fires",
      "lineHeight": 1.5
    },
